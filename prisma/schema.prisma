generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  sortOrder Int       @default(0)
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id          String   @id @default(uuid())
  name        String
  subtitle    String
  price       Float
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  badge       String?
  image       String
  inStock     Boolean  @default(true)
  description String?
  wishlists   Wishlist[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id        String   @id @default(uuid())
  items     Json
  total     Float
  summary   String?
  type      String   @default("cart")
  phone     String?
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CustomBuild {
  id        String   @id @default(uuid())
  baseId    String
  baseName  String
  basePrice Float
  extras    Json     @default("[]")
  neckSize  String?
  wristSize String?
  total     Float
  summary   String?
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Wishlist {
  id        String   @id @default(uuid())
  sessionId String
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  createdAt DateTime @default(now())

  @@unique([sessionId, productId])
}

model Testimonial {
  id        String   @id @default(uuid())
  name      String
  role      String?
  quote     String
  image     String?
  rating    Int      @default(5)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GalleryImage {
  id        String   @id @default(uuid())
  url       String
  caption   String?
  section   String   @default("lookbook")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}